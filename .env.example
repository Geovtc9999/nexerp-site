# NEXERP — Configuration backend
# Copier ce fichier en .env et remplir les valeurs.

# Port d'écoute du serveur (par défaut 3000)
PORT=3000

# --- Configuration SMTP pour l'envoi du formulaire de contact ---
# Si SMTP_HOST n'est pas défini, le formulaire fonctionne en mode DEV (log console).
#
# Les emails NEXERP sont hébergés chez GOOGLE WORKSPACE (Gmail Pro).
# => On envoie via le SMTP de Gmail avec la boîte contact@nexerp.fr.

# ── PRÉREQUIS Google Workspace ──────────────────────────────────────
# 1. Activer la validation en 2 étapes sur le compte contact@nexerp.fr
#    (admin Workspace : Sécurité > Authentification).
# 2. Générer un "Mot de passe d'application" (App Password, 16 caractères) :
#    https://myaccount.google.com/apppasswords  → à mettre dans SMTP_PASS.
#    (Le mot de passe normal du compte NE fonctionne PAS avec SMTP.)
# 3. IMPORTANT : avec smtp.gmail.com, l'expéditeur (MAIL_FROM) DOIT être
#    l'adresse authentifiée (SMTP_USER) ou un alias vérifié "Envoyer en tant que".
#    => On garde donc MAIL_FROM = contact@nexerp.fr (et non un no-reply@).

# ── Option A (recommandée) : SMTP Gmail authentifié ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@nexerp.fr
SMTP_PASS=app_password_16_caracteres

# ── Option B : SMTP relay Google Workspace (avancé) ─────────────────
# Permet d'envoyer depuis n'importe quelle adresse du domaine, quotas plus
# élevés. À activer dans la console admin (Apps > Gmail > Routing > SMTP relay).
# SMTP_HOST=smtp-relay.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=contact@nexerp.fr
# SMTP_PASS=app_password_16_caracteres

# Adresse d'expéditeur — DOIT être contact@nexerp.fr (= SMTP_USER) ou un alias vérifié
MAIL_FROM=contact@nexerp.fr

# Adresse de réception des messages du formulaire
MAIL_TO=contact@nexerp.fr
